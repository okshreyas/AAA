function clearConsoleAfterDuration(durationInMinutes) {
  const durationInMilliseconds = durationInMinutes * 60 * 1000;

  // Clear console initially
  console.clear();

  // Set up an interval to clear the console after the specified duration
  const intervalId = setInterval(function () {
    console.clear();
  }, durationInMilliseconds);

  // Clear interval after the specified duration
  setTimeout(function () {
    clearInterval(intervalId);
  }, durationInMilliseconds);
}

// Example usage: Clear console every 40 minutes
clearConsoleAfterDuration(40);