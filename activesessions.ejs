-- Define the list of skills
SET @skills := 'Javascript,java,python,cloud,html,css';

-- Update existing rows in the "users" table with random skills
UPDATE users
SET
    pskill = SUBSTRING_INDEX(SUBSTRING_INDEX(@skills, ',', RAND() * (LENGTH(@skills) - LENGTH(REPLACE(@skills, ',', '')) + 1)), ',', -1),
    currskill = SUBSTRING_INDEX(SUBSTRING_INDEX(@skills, ',', RAND() * (LENGTH(@skills) - LENGTH(REPLACE(@skills, ',', '')) + 1)), ',', -1),
    desskill = SUBSTRING_INDEX(SUBSTRING_INDEX(@skills, ',', RAND() * (LENGTH(@skills) - LENGTH(REPLACE(@skills, ',', '')) + 1)), ',', -1)
WHERE id >= 3;