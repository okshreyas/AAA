-- Define the list of skills
SET @skills := 'Javascript,java,python,cloud,html,css';

-- Insert random skills into the "users" table
INSERT INTO users (pskill, currskill, desskill)
SELECT
    SUBSTRING_INDEX(SUBSTRING_INDEX(@skills, ',', RAND() * (LENGTH(@skills) - LENGTH(REPLACE(@skills, ',', '')) + 1)), ',', -1) AS pskill,
    SUBSTRING_INDEX(SUBSTRING_INDEX(@skills, ',', RAND() * (LENGTH(@skills) - LENGTH(REPLACE(@skills, ',', '')) + 1)), ',', -1) AS currskill,
    SUBSTRING_INDEX(SUBSTRING_INDEX(@skills, ',', RAND() * (LENGTH(@skills) - LENGTH(REPLACE(@skills, ',', '')) + 1)), ',', -1) AS desskill
FROM
    (SELECT n FROM (SELECT 1 AS n UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 UNION ALL SELECT 5 UNION ALL SELECT 6) AS nums) AS random_nums
CROSS JOIN
    (SELECT @rownum := @rownum + 1 AS id
     FROM (SELECT 0 UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 UNION ALL SELECT 5) t,
          (SELECT 0 UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 UNION ALL SELECT 5) t2,
          (SELECT 0 UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 UNION ALL SELECT 5) t3,
          (SELECT @rownum := -1) r) AS id_generator;