INSERT INTO users (column1, column2, column3)
SELECT
    CASE WHEN RAND() < 0.1667 THEN 'Javascript'
         WHEN RAND() < 0.3333 THEN 'java'
         WHEN RAND() < 0.5 THEN 'python'
         WHEN RAND() < 0.6667 THEN 'cloud'
         WHEN RAND() < 0.8333 THEN 'html'
         ELSE 'css'
    END AS column1,
    CASE WHEN RAND() < 0.1667 THEN 'Javascript'
         WHEN RAND() < 0.3333 THEN 'java'
         WHEN RAND() < 0.5 THEN 'python'
         WHEN RAND() < 0.6667 THEN 'cloud'
         WHEN RAND() < 0.8333 THEN 'html'
         ELSE 'css'
    END AS column2,
    CASE WHEN RAND() < 0.1667 THEN 'Javascript'
         WHEN RAND() < 0.3333 THEN 'java'
         WHEN RAND() < 0.5 THEN 'python'
         WHEN RAND() < 0.6667 THEN 'cloud'
         WHEN RAND() < 0.8333 THEN 'html'
         ELSE 'css'
    END AS column3
FROM
    (SELECT t1.id, t2.*
     FROM (SELECT @rownum := @rownum + 1 AS id
           FROM (SELECT 0 UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 UNION ALL SELECT 5) t,
                (SELECT 0 UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 UNION ALL SELECT 5) t2,
                (SELECT 0 UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 UNION ALL SELECT 5) t3,
                (SELECT @rownum := -1) r) t1
     CROSS JOIN emp t2) t;